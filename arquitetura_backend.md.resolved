│   ├── ai/gemini_service.py       # Integração Google Gemini
│   ├── pdf/                       # Utilitários PDF (WeasyPrint)
│   ├── signature/                 # Integração Gov.br PAdES
│   ├── search/                    # Busca global
│   └── utils/
│       ├── response.py            # api_success, api_error, api_created...
│       ├── pagination.py          # TratheaPagination
│       ├── exceptions.py          # custom_exception_handler
│       ├── validators.py
│       └── sanitizers.py
│
├── core_app/                      # ← Usuário e autenticação

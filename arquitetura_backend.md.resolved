│   ├── views/
│   │   ├── receita_crud.py        # CRUD de receitas
│   │   ├── receita_assinatura.py  # Assinatura digital Gov.br
│   │   ├── receita_verificacao.py # Verificação pública via hash/QR
│   │   └── receita_pdf.py         # 🆕 Geração de PDF com WeasyPrint
│   ├── services/
│   │   └── govbr_assinar_service.py
│   └── urls_receitas.py / urls_medicamentos.py / urls_verificacao.py
│
├── exame_app/                     # ← Módulo Exames
├── admin_app/                     # ← Painel Admin + Solicitações
│
├── templates/
│   └── pdf/receita.html           # Template HTML da receita médica
│
├── tests/                         # Testes automatizados (pytest-django)
├── requirements.txt
├── manage.py
└── .env                           # Variáveis de ambiente (não versionar)
```


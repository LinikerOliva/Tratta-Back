│   └── settings/
│       ├── base.py                # Configurações compartilhadas
│       ├── dev.py                 # Desenvolvimento (DEBUG=True, SQLite)
│       └── prod.py                # Produção (PostgreSQL, HTTPS, WhiteNoise)
│
├── trathea_core/                  # ← Serviços transversais reutilizáveis
│   ├── auth/permissions.py        # Classes de permissão RBAC
│   ├── audit/

│   ├── serializers.py
│   └── urls/
│       ├── auth_urls.py           # /api/auth/*
│       └── user_urls.py           # /api/users/*
│
├── medico_app/                    # ← Módulo Médico
├── paciente_app/                  # ← Módulo Paciente + Prontuários
├── clinica_app/                   # ← Módulo Clínica + Secretaria
├── consulta_app/                  # ← Consultas + Agendamentos
├── prescricao_app/                # ← Receitas + Medicamentos (mais complexo)

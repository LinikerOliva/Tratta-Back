# ============================================================
# TRATHEA — Variáveis de Ambiente (.env.example)
# Copie para .env e preencha os valores reais
# NUNCA comite o .env no repositório!
# ============================================================

# ── Ambiente ────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=trathea_orchestrator.settings.dev
DEBUG=True
SECRET_KEY=sua-chave-secreta-aqui-minimo-50-caracteres-use-gerador

# ── Banco de Dados ────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=trathea_db
DB_USER=trathea_user
DB_PASSWORD=sua_senha_segura
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Gov.br OAuth2 ─────────────────────────────────────────────
GOVBR_CLIENT_ID=seu_client_id_govbr
GOVBR_CLIENT_SECRET=seu_client_secret_govbr
GOVBR_REDIRECT_URI=http://localhost:8000/api/auth/govbr/callback/
GOVBR_AUTH_URL=https://sso.staging.acesso.gov.br/authorize
GOVBR_TOKEN_URL=https://sso.staging.acesso.gov.br/token
GOVBR_USERINFO_URL=https://sso.staging.acesso.gov.br/userinfo
GOVBR_SIGNATURE_URL=https://assinatura.staging.iti.br/externo/pdf/assinar

# ── Google Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_api

# ── Celery / Redis ────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email ────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@trathea.app
EMAIL_HOST_PASSWORD=sua_senha_email

# ── Frontend URL (para links em emails) ──────────────────────
FRONTEND_URL=http://localhost:5173

# ── Armazenamento de Mídia ───────────────────────────────────
MEDIA_ROOT=media/
MEDIA_URL=/media/
